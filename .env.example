# Server
PORT=3100

# LLM providers
# Leave keys empty until you configure a local provider.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_BASE_URL=https://api.openai.com/v1

DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_BASE_URL=https://api.deepseek.com

LLM_TIMEOUT_MS=120000
ENABLE_LLM_ROLE_LABELING=false

ALI_API_KEY=
ALI_MODEL=qwen-plus
ALI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ASR providers
ASR_PROVIDER_DEFAULT=auto
ALI_ASR_MODEL=qwen3-asr-flash
ALI_ASR_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
ALI_ASR_CHUNK_SECONDS=300
ALI_ASR_CHUNK_BITRATE=32k

# Optional OpenAI-compatible Whisper endpoint
WHISPER_API_KEY=
WHISPER_MODEL=whisper-1
WHISPER_API_URL=https://api.openai.com/v1/audio/transcriptions
WHISPER_LANGUAGE=zh
WHISPER_PROMPT=

# Optional local Whisper
LOCAL_WHISPER_MODEL=medium
LOCAL_WHISPER_BEAM_SIZE=8
LOCAL_WHISPER_TEMPERATURE=0
LOCAL_WHISPER_CONDITION_ON_PREVIOUS_TEXT=false

# Optional PDF text fallback. Uses "python" by default and requires PyMuPDF.
PDF_TEXT_PYTHON=python

# Optional public research enrichment
TAVILY_API_KEY=
SERPAPI_API_KEY=
